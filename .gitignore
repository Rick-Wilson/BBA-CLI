# Build outputs
/dist/
/build/
bin/
obj/

# Rust
**/target/
**/*.rs.bk
# epbot-core is a library consumed only via path by the binary crates;
# its lockfile is unused, the binaries' own lockfiles govern.
epbot-core/Cargo.lock

# .NET build artifacts
*.nupkg
packages/

# C++/CLI build artifacts (legacy/epbot-wrapper/)
*.obj
*.pch
*.idb
*.ilk

# Test executables created during development
test-epbot*.exe
test-epbot*.cs
inspect-*.ps1

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.vcxproj.user

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

# Test outputs
/test/output*.pbn

# Logs
*.log
bba-server/logs/

# Generated PDFs (created by GitHub Actions)
CLI-README.pdf

# Auto-update artifacts
auto-updated.txt
*.old

# Don't ignore the DLLs we need
!EPBot64.dll
!EPBot86.dll
!EPBotARM64.dll
!EPBot64.tlb
!EPBot86.tlb

# Don't ignore native EPBot libraries
!epbot-libs/**/*.dll
!epbot-libs/**/*.so
!epbot-libs/**/*.dylib

# Private research/notes (not for publishing)
EPBOT-CROSSPLATFORM-RESEARCH.md

# Local config with secrets (not tracked)
appsettings.Local.json
activity-log.json
